---
---

<!-- Mobile Menu Overlay -->
<div id="mobile-menu-overlay" class="fixed inset-0 bg-black/50 z-40 opacity-0 pointer-events-none transition-opacity duration-300 md:hidden" aria-hidden="true"></div>

<!-- Mobile Menu Sidebar -->
<aside id="mobile-menu" class="fixed top-0 left-0 h-full w-72 bg-surface-container-high z-50 transform -translate-x-full transition-transform duration-300 ease-out md:hidden" aria-label="Mobile navigation">
  <!-- Close Button -->
  <button id="mobile-menu-close" class="absolute top-4 right-4 p-2 text-on-surface hover:text-primary transition-colors" aria-label="Close menu">
    <span class="material-symbols-outlined text-2xl">&#xe5cd;</span>
  </button>

  <!-- Menu Content -->
  <div class="flex flex-col h-full pt-16 px-6 pb-8">
    <!-- Navigation Links -->
    <nav class="flex-1 space-y-2">
      <a href="/" class="block py-3 px-4 font-headline text-lg font-semibold tracking-tight text-on-surface hover:bg-surface-container-highest transition-colors rounded">
        HOME
      </a>
      <a href="/blog" class="block py-3 px-4 font-headline text-lg font-semibold tracking-tight text-on-surface hover:bg-surface-container-highest transition-colors rounded">
        ARTICLES
      </a>
      <a href="/archive" class="block py-3 px-4 font-headline text-lg font-semibold tracking-tight text-on-surface hover:bg-surface-container-highest transition-colors rounded">
        ARCHIVE
      </a>
      <a href="/subscribe" class="block py-3 px-4 font-headline text-lg font-semibold tracking-tight text-on-surface hover:bg-surface-container-highest transition-colors rounded">
        SUBSCRIBE
      </a>
    </nav>

    <div id="reading-progress-toggle-mobile-wrapper" class="pt-2 pb-2 hidden">
      <button
        id="reading-progress-toggle-mobile"
        class="w-full flex items-center justify-center gap-3 py-3 px-4 border border-outline-variant text-on-surface hover:bg-surface-container transition-colors rounded"
        type="button"
        aria-label="Toggle reading progress navigation"
        aria-pressed="true"
      >
        <span class="material-symbols-outlined text-xl" data-role="icon">&#xe06a;</span>
        <span class="font-label text-sm tracking-widest uppercase notranslate" translate="no" data-role="label">NAV ON</span>
      </button>
    </div>

    <!-- Dark Mode Toggle (Mobile) -->
    <div class="pt-4 pb-2">
      <button id="theme-toggle-mobile" class="w-full flex items-center justify-center gap-3 py-3 px-4 border border-outline-variant text-on-surface hover:bg-surface-container transition-colors rounded">
        <span class="material-symbols-outlined text-xl">&#xe51c;</span>
        <span class="font-label text-sm tracking-widest uppercase notranslate" translate="no">DARK</span>
      </button>
    </div>

    <!-- Bottom Icons -->
    <div class="flex items-center justify-center gap-8 pt-4 border-t border-outline-variant">
      <a href="https://github.com/chinskylee" target="_blank" rel="noopener noreferrer" class="p-3 text-on-surface hover:text-primary transition-colors" aria-label="GitHub">
        <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
        </svg>
      </a>
      <a href="mailto:chinskylee@outlook.com" class="p-3 text-on-surface hover:text-primary transition-colors" aria-label="Email">
        <span class="material-symbols-outlined text-3xl">&#xe158;</span>
      </a>
    </div>
  </div>
</aside>

<script>
  (function() {
    const menu = document.getElementById('mobile-menu');
    const overlay = document.getElementById('mobile-menu-overlay');
    const toggleBtnNav = document.getElementById('mobile-menu-toggle-nav');
    const menuIcon = document.getElementById('menu-icon');
    const closeBtn = document.getElementById('mobile-menu-close');
    const themeToggleMobile = document.getElementById('theme-toggle-mobile');
    const readingProgressToggleMobile = document.getElementById('reading-progress-toggle-mobile');
    const readingProgressToggleWrapper = document.getElementById('reading-progress-toggle-mobile-wrapper');

    const READING_PROGRESS_KEY = 'readingProgressNavEnabledMobile';
    const READING_PROGRESS_EVENT = 'reading-progress-visibility-change';
    const isBlogArticlePage = /^\/blog\/.+/.test(window.location.pathname) && !/^\/blog\/?$/.test(window.location.pathname);
    
    if (!menu) return;

    if (readingProgressToggleWrapper) {
      readingProgressToggleWrapper.classList.toggle('hidden', !isBlogArticlePage);
    }

    let isOpen = false;
    let touchStartX = 0;
    let touchEndX = 0;

    function openMenu() {
      isOpen = true;
      menu.classList.remove('-translate-x-full');
      overlay.classList.remove('opacity-0', 'pointer-events-none');
      document.body.style.overflow = 'hidden';
      syncMobileThemeToggle();
      // 切换图标为 close
      if (menuIcon) menuIcon.textContent = '\ue5cd';
    }

    function closeMenu() {
      isOpen = false;
      menu.classList.add('-translate-x-full');
      overlay.classList.add('opacity-0', 'pointer-events-none');
      document.body.style.overflow = '';
      // 切换图标为 menu
      if (menuIcon) menuIcon.textContent = '\ue5d2';
    }

    function toggleMenu() {
      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    }

    // Toggle button click (from NavBar) - 现在可以开关
    if (toggleBtnNav) toggleBtnNav.addEventListener('click', toggleMenu);
    
    // Close button click
    if (closeBtn) closeBtn.addEventListener('click', closeMenu);
    
    // Overlay click
    if (overlay) overlay.addEventListener('click', closeMenu);

    // Mobile theme toggle
    const syncMobileThemeToggle = () => {
      if (!themeToggleMobile) {
        return;
      }

      const isDark = document.documentElement.classList.contains('dark');
      const mobileIcon = themeToggleMobile.querySelector<HTMLElement>('.material-symbols-outlined');
      const mobileLabel = themeToggleMobile.querySelector<HTMLElement>('span.notranslate, span:last-child');

      if (mobileIcon) {
        // icon/label show what clicking will do next
        mobileIcon.textContent = isDark ? '\ue518' : '\ue51c';
      }

      if (mobileLabel) {
        mobileLabel.textContent = isDark ? 'LIGHT' : 'DARK';
        mobileLabel.setAttribute('translate', 'no');
      }

      themeToggleMobile.setAttribute(
        'aria-label',
        isDark ? 'Switch to light mode' : 'Switch to dark mode',
      );
    };

    if (themeToggleMobile) {
      syncMobileThemeToggle();

      themeToggleMobile.addEventListener('click', function() {
        const isDark = document.documentElement.classList.contains('dark');
        const newTheme = isDark ? 'light' : 'dark';
        document.documentElement.classList.toggle('dark', !isDark);
        document.documentElement.classList.toggle('light', isDark);
        
        // Update main toggle button if exists
        const mainToggleIcon = document.getElementById('theme-toggle-icon');
        if (mainToggleIcon) mainToggleIcon.textContent = !isDark ? '\ue518' : '\ue51c';
        syncMobileThemeToggle();
        
        try {
          window.localStorage.setItem('theme', newTheme);
        } catch {}
      });
    }

    // Reading progress toggle (only rendered on blog detail pages)
    if (readingProgressToggleMobile && isBlogArticlePage) {
      const readProgressEnabled = () => {
        try {
          return window.localStorage.getItem(READING_PROGRESS_KEY) !== 'false';
        } catch {
          return true;
        }
      };

      const writeProgressEnabled = (enabled) => {
        try {
          window.localStorage.setItem(READING_PROGRESS_KEY, enabled ? 'true' : 'false');
        } catch {
          // Ignore write failures
        }
      };

      const updateProgressToggleUI = (enabled) => {
        const icon = readingProgressToggleMobile.querySelector('[data-role="icon"]');
        const label = readingProgressToggleMobile.querySelector('[data-role="label"]');

        readingProgressToggleMobile.setAttribute('aria-pressed', String(enabled));

        if (icon) {
          icon.textContent = enabled ? '\ue06a' : '\ue8f5';
        }

        if (label) {
          label.textContent = enabled ? 'NAV ON' : 'NAV OFF';
        }
      };

      let progressEnabled = readProgressEnabled();
      updateProgressToggleUI(progressEnabled);

      window.dispatchEvent(new CustomEvent(READING_PROGRESS_EVENT, {
        detail: { enabled: progressEnabled },
      }));

      readingProgressToggleMobile.addEventListener('click', () => {
        progressEnabled = !progressEnabled;
        updateProgressToggleUI(progressEnabled);
        writeProgressEnabled(progressEnabled);

        window.dispatchEvent(new CustomEvent(READING_PROGRESS_EVENT, {
          detail: { enabled: progressEnabled },
        }));
      });
    }

    // Touch events for swipe
    document.addEventListener('touchstart', function(e) {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });

    document.addEventListener('touchend', function(e) {
      touchEndX = e.changedTouches[0].screenX;
      handleSwipe();
    }, { passive: true });

    function handleSwipe() {
      const swipeThreshold = 50;
      const diff = touchStartX - touchEndX;

      // Left to right swipe (open menu) - only when near left edge
      if (touchStartX < 50 && diff < -swipeThreshold && !isOpen) {
        openMenu();
      }
      
      // Right to left swipe (close menu) - only when menu is open
      if (diff > swipeThreshold && isOpen) {
        closeMenu();
      }
    }

    // Close menu on escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && isOpen) {
        closeMenu();
      }
    });
  })();
</script>
