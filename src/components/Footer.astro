---
const currentYear = new Date().getFullYear();
---

<footer class="w-full border-t border-[#79776d]/10 bg-[#f5f4e8] dark:bg-[#1b1c15] flex items-center justify-center px-8 py-6 gap-4 mt-24">
  <div class="font-['Space_Grotesk'] text-base leading-tight text-[#705a4a] dark:text-[#f5f4e8]">
    © {currentYear} SYSTEM_ERR_NULL // ALL_EQUATIONS_RESERVED
  </div>
</footer>

<button 
  aria-label="Back to top" 
  class="hidden fixed right-6 bottom-8 z-40 border border-outline bg-surface-container text-on-surface px-3 py-3 hover:bg-surface-container-highest transition-colors" 
  id="back-to-top" 
  type="button"
>
  <span class="material-symbols-outlined text-base">arrow_upward</span>
</button>