---
const navLinks = [
  { href: '/blog', label: 'ARTICLES' },
  { href: '/archive', label: 'ARCHIVE' },
  { href: '/subscribe', label: 'SUBSCRIBE' },
];

const currentPath = Astro.url.pathname;
---

<nav class="fixed top-0 w-full rounded-none border-b border-[#79776d]/20 dark:border-[#9f9c90]/20 bg-[#fbfaee] dark:bg-[#1b1c15] flex justify-between items-center px-6 py-4 max-w-full z-50">
  <!-- Mobile Menu Button (Left side) -->
  <button id="mobile-menu-toggle-nav" class="md:hidden p-2 text-on-surface hover:text-primary transition-colors" aria-label="Toggle menu">
    <span id="menu-icon" class="material-symbols-outlined text-2xl">menu</span>
  </button>
  
  <a href="/" class="hidden md:block font-bold text-lg tracking-widest text-[#705a4a] dark:text-[#f5f4e8] font-['Space_Grotesk'] uppercase">
    TERMINAL_V1.0
  </a>
  
  <!-- Spacer for mobile to balance layout -->
  <div class="md:hidden w-10"></div>
  
  <div class="flex items-center gap-3 md:gap-8">
    <div class="hidden md:flex gap-8 items-center pr-2 md:pr-4">
      {navLinks.map(link => {
        const isActive = currentPath === link.href || currentPath.startsWith(link.href + '/');
        return (
          <a 
            href={link.href}
            class:list={[
              "nav-link font-['Space_Grotesk'] tracking-tight uppercase text-base pb-1 transition-colors duration-150 border-b-2",
              isActive 
                ? "text-[#705a4a] border-[#705a4a] dark:text-[#dec1ad] dark:border-[#dec1ad]"
                : "text-[#79776d] dark:text-[#a9a596] border-transparent hover:text-[#705a4a] dark:hover:text-[#dec1ad]"
            ]}
            aria-current={isActive ? 'page' : undefined}
          >
            {link.label}
          </a>
        );
      })}
    </div>
    <button
      aria-label="Switch to dark mode"
      aria-pressed="false"
      class="theme-toggle group border border-outline-variant bg-surface-container-low px-2 py-2 hover:bg-surface-container transition-colors w-[110px] shrink-0 hidden sm:block"
      id="theme-toggle"
      type="button"
      transition:persist
    >
      <span class="inline-flex items-center justify-center gap-1.5 w-full">
        <span class="material-symbols-outlined text-base text-on-surface transition-all duration-150 shrink-0" id="theme-toggle-icon" style="font-size: 20px; width: 20px; height: 20px;">dark_mode</span>
        <span class="theme-dot shrink-0" aria-hidden="true"></span>
        <span class="font-label text-sm tracking-widest uppercase text-on-surface w-[40px] text-center relative" id="theme-toggle-label">
          <span class="dark:hidden">DARK</span>
          <span class="hidden dark:inline">LIGHT</span>
        </span>
      </span>
    </button>
  </div>
</nav>

<script is:inline>
  // Sync icon with current theme immediately after button renders
  (function() {
    var icon = document.getElementById('theme-toggle-icon');
    if (icon && !icon.dataset.synced) {
      var isDark = document.documentElement.classList.contains('dark');
      icon.textContent = isDark ? 'light_mode' : 'dark_mode';
      icon.dataset.synced = 'true';
    }
  })();
</script>