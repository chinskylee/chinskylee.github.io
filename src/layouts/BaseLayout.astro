---
export interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Physics Student Blog' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta content="width=device-width, initial-scale=1.0" name="viewport">
  <title>{title}</title>
  <meta name="description" content={description}>
  
  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,300,0,0&display=block" rel="stylesheet">
  
  <!-- Theme Init Script - Set HTML class and initial icon -->
  <script is:inline>
    (function() {
      var storedTheme = null;
      try {
        storedTheme = window.localStorage.getItem('theme');
      } catch (e) {
        storedTheme = null;
      }
      var prefersDarkTheme = window.matchMedia('(prefers-color-scheme: dark)').matches;
      var initialTheme = storedTheme === 'dark' || storedTheme === 'light'
        ? storedTheme
        : (prefersDarkTheme ? 'dark' : 'light');
      var isDark = initialTheme === 'dark';
      document.documentElement.classList.toggle('dark', isDark);
      document.documentElement.classList.toggle('light', !isDark);
      
      // Sync initial icon to match theme (icon shows what clicking will do)
      var icon = document.getElementById('theme-toggle-icon');
      if (icon) {
        icon.textContent = isDark ? 'light_mode' : 'dark_mode';
      }
    })();
  </script>
</head>
<body class="font-body selection:bg-primary-fixed selection:text-on-primary-fixed">
  <slot />
</body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
    /* 防止滚动条导致的布局抖动 */
    scrollbar-gutter: stable;
    overflow-y: scroll;
    /* 全局滚动吸附 - mandatory 强制吸附 */
    scroll-snap-type: y mandatory;
  }
  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }
  }
  html.loading {
    scroll-behavior: auto !important;
  }
  /* 隐藏滚动条但保留滚动功能 */
  html::-webkit-scrollbar {
    width: 0px;
    background: transparent;
  }
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
    vertical-align: middle;
    font-size: 24px;
    width: 24px;
    height: 24px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  body {
    background-color: #fbfaee;
    color: #1b1c15;
    cursor: crosshair;
    transition: background-color 0.2s ease, color 0.2s ease;
  }
  .dark body {
    background-color: #15160f;
    color: #edeadf;
  }
  .terminal-block::after {
    content: '_';
    animation: blink 1s step-end infinite;
  }
  /* 竖长方形光标样式 */
  .terminal-cursor {
    display: inline-block;
    width: 10px;
    height: 22px;
    background-color: currentColor;
    animation: blink 1s step-end infinite;
  }
  @keyframes blink {
    from, to { opacity: 1; }
    50% { opacity: 0; }
  }
  .custom-scrollbar::-webkit-scrollbar {
    width: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: #f5f4e8;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: #79776d;
  }
  .dark .custom-scrollbar::-webkit-scrollbar-track {
    background: #1f2019;
  }
  .dark .custom-scrollbar::-webkit-scrollbar-thumb {
    background: #6e6a5f;
  }
  .dark .bg-surface-container-low {
    background-color: #1f2019;
  }
  .dark .bg-surface-container {
    background-color: #262821;
  }
  .dark .bg-surface-container-highest {
    background-color: #2f3128;
  }
  .dark .hover\:bg-surface-container:hover {
    background-color: #262821;
  }
  .dark .hover\:bg-surface-container-highest:hover {
    background-color: #2f3128;
  }
  .dark .text-on-surface {
    color: #f1eee2;
  }
  .dark .text-on-surface-variant {
    color: #c1beb2;
  }
  .dark .text-outline {
    color: #9f9c90;
  }
  .dark .border-outline {
    border-color: #6f6c60;
  }
  .dark .border-outline-variant {
    border-color: #59574d;
  }
  .dark .bg-background {
    background-color: #1b1c15;
  }
  .theme-toggle {
    position: relative;
    overflow: hidden;
    box-shadow: inset 0 0 0 1px rgba(121, 119, 109, 0.18);
  }
  .theme-toggle::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, rgba(112, 90, 74, 0) 0%, rgba(112, 90, 74, 0.18) 48%, rgba(112, 90, 74, 0) 100%);
    transform: translateX(-140%);
    transition: transform 0.45s ease;
    pointer-events: none;
  }
  .theme-toggle:hover::before,
  .theme-toggle:focus-visible::before {
    transform: translateX(0%);
  }
  .theme-toggle:focus-visible {
    outline: 1px solid #705a4a;
    outline-offset: 2px;
  }
  .theme-toggle .theme-dot {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background: #705a4a;
    box-shadow: 0 0 0 rgba(112, 90, 74, 0.55);
    animation: terminalPulse 2.2s ease-in-out infinite;
  }
  .dark .theme-toggle {
    box-shadow: inset 0 0 0 1px rgba(159, 156, 144, 0.24);
  }
  .dark .theme-toggle::before {
    background: linear-gradient(120deg, rgba(222, 193, 173, 0) 0%, rgba(222, 193, 173, 0.2) 50%, rgba(222, 193, 173, 0) 100%);
  }
  .dark .theme-toggle:focus-visible {
    outline-color: #dec1ad;
  }
  .dark .theme-toggle .theme-dot {
    background: #dec1ad;
    box-shadow: 0 0 0 rgba(222, 193, 173, 0.55);
  }
  @keyframes terminalPulse {
    0%, 100% {
      opacity: 0.62;
      box-shadow: 0 0 0 rgba(112, 90, 74, 0);
    }
    50% {
      opacity: 1;
      box-shadow: 0 0 10px rgba(112, 90, 74, 0.5);
    }
  }
</style>

<script>
  // Page load handling
  document.documentElement.classList.add('loading');
  window.addEventListener('load', () => {
    document.documentElement.classList.remove('loading');
  });

  // Theme toggle functionality - only initialize once
  (function initThemeToggle() {
    const themeToggleButton = document.getElementById('theme-toggle');
    if (!themeToggleButton || themeToggleButton.dataset.initialized) return;
    
    // Mark as initialized to prevent duplicate handlers
    themeToggleButton.dataset.initialized = 'true';

    const themeToggleIcon = document.getElementById('theme-toggle-icon');
    const themeToggleLabel = document.getElementById('theme-toggle-label');
    if (!themeToggleIcon || !themeToggleLabel) return;

    const writeStoredTheme = (theme) => {
      try {
        window.localStorage.setItem('theme', theme);
      } catch {
        // Ignore
      }
    };

    // Set initial aria attributes
    const isDark = document.documentElement.classList.contains('dark');
    themeToggleButton.setAttribute('aria-pressed', String(isDark));
    themeToggleButton.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
    // Note: Label text is controlled by CSS (dark: classes), no JS update needed

    // Handle click
    themeToggleButton.addEventListener('click', () => {
      const isDark = document.documentElement.classList.contains('dark');
      const newTheme = isDark ? 'light' : 'dark';

      // Toggle theme class immediately (CSS will handle label text)
      document.documentElement.classList.toggle('dark', !isDark);
      document.documentElement.classList.toggle('light', isDark);

      // Update icon - icon shows current state (light mode = light_mode icon)
      themeToggleIcon.textContent = !isDark ? 'light_mode' : 'dark_mode';
      themeToggleButton.setAttribute('aria-pressed', String(!isDark));
      themeToggleButton.setAttribute('aria-label', !isDark ? 'Switch to light mode' : 'Switch to dark mode');

      writeStoredTheme(newTheme);
    });
  })();

  // Back to top button
  function initBackToTop() {
    const backToTopButton = document.getElementById('back-to-top');
    if (!backToTopButton) return;
    
    const updateBackToTopVisibility = () => {
      const shouldShow = window.scrollY > 320;
      if (shouldShow) {
        backToTopButton.classList.remove('hidden');
        backToTopButton.style.display = 'flex';
      } else {
        backToTopButton.classList.add('hidden');
        backToTopButton.style.display = '';
      }
    };

    backToTopButton.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    // Scroll handling with RAF
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          updateBackToTopVisibility();
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    updateBackToTopVisibility();
  }

  initBackToTop();
  document.addEventListener('astro:page-load', initBackToTop);

  // Initialize
  updateBackToTopVisibility();
</script>