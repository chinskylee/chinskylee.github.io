---
import BaseLayout from '../layouts/BaseLayout.astro';
import NavBar from '../components/NavBar.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import TerminalLog from '../components/TerminalLog.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const recentPosts = posts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="PHYSICIST_TERMINAL_V1.0 // Chinsky Lee">
  <NavBar />

  <main class="pt-24 pb-12 px-6 max-w-7xl mx-auto space-y-32">
    <Hero />
    <TerminalLog />
    
    <!-- Recent Posts Section -->
    <section class="space-y-8 border-t border-outline-variant pt-24 scroll-mt-28" id="articles" style="scroll-snap-align: none;">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
          <h2 class="font-headline text-4xl font-bold tracking-tight scroll-mt-28" id="articles-heading">FEATURED_POSTS</h2>
          <p class="font-label text-base text-outline uppercase tracking-widest mt-2">Modest insights into physics & tech notes</p>
        </div>
        <a class="text-lg font-label border-b border-on-surface pb-1 hover:text-primary transition-colors" href="/blog">VIEW_ALL_RECORDS</a>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {recentPosts.map(post => (
          <a href={`/blog/${post.slug}/`} class="group bg-surface-container p-4 flex flex-col gap-4 hover:bg-surface-container-highest transition-colors min-h-[200px]">
            <div class="space-y-2 flex-1">
              <span class="font-label text-xs text-outline block h-5">
                {post.data.pubDate.toISOString().split('T')[0]}
              </span>
              <h3 class="font-headline text-2xl font-bold leading-tight min-h-[64px]">{post.data.title}</h3>
              <p class="text-base text-on-surface-variant line-clamp-3 min-h-[72px]">{post.data.description}</p>
            </div>
            <div class="flex items-center justify-between pt-4 border-t border-outline/10 mt-auto">
              <span class="font-label text-sm uppercase">READ_MORE</span>
              <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform flex-shrink-0">arrow_forward</span>
            </div>
          </a>
        ))}
        
        {recentPosts.length === 0 && (
          <div class="col-span-3 text-center py-12 text-on-surface-variant">
            <p class="text-lg">No posts yet. Check back soon!</p>
          </div>
        )}
      </div>
    </section>
    
    <!-- GitHub Projects Section -->
    <section class="grid md:grid-cols-2 gap-12 border-t border-outline-variant pt-24 scroll-mt-28" id="projects">
      <div class="space-y-6">
        <h2 class="font-headline text-4xl font-bold tracking-tight scroll-mt-28" id="projects-heading">GITHUB_PROJECTS</h2>
        <p class="text-on-surface-variant text-xl max-w-md leading-relaxed">
          Lately, I've been leaning into the intuition of vibe coding. On GitHub, you'll find my modest attempts at AI-assisted programming—rough prototypes and evolving experiments as I learn to co-create with LLMs.
        </p>
        <div class="pt-4">
          <a class="inline-flex items-center gap-4 group" href="https://github.com/chinskylee" rel="noopener noreferrer" target="_blank">
            <div class="w-12 h-12 flex items-center justify-center border border-outline group-hover:bg-primary group-hover:text-on-primary transition-all">
              <span class="material-symbols-outlined">code</span>
            </div>
            <div>
              <span class="block font-headline font-bold text-lg tracking-widest uppercase">Visit Repository</span>
              <span class="text-sm font-label text-outline uppercase">github.com/chinskylee</span>
            </div>
          </a>
        </div>
      </div>
      <div class="space-y-4">
        <!-- Repo 1 -->
        <div class="bg-surface-container-low p-4 flex items-center justify-between hover:bg-surface-container transition-colors">
          <div class="flex items-center gap-4">
            <span class="material-symbols-outlined text-primary">folder</span>
            <div>
              <span class="block font-label text-lg font-bold">quantum-sim-v3</span>
              <span class="text-base text-outline uppercase">Python / NumPy / C++</span>
            </div>
          </div>
          <div class="flex items-center gap-4 text-outline font-label text-base">
            <span>★ 1.2k</span>
            <span class="material-symbols-outlined text-base">fork_right</span>
          </div>
        </div>
        <!-- Repo 2 -->
        <div class="bg-surface-container-low p-4 flex items-center justify-between hover:bg-surface-container transition-colors">
          <div class="flex items-center gap-4">
            <span class="material-symbols-outlined text-primary">folder</span>
            <div>
              <span class="block font-label text-lg font-bold">entropy-vis-engine</span>
              <span class="text-base text-outline uppercase">TypeScript / WebGL</span>
            </div>
          </div>
          <div class="flex items-center gap-4 text-outline font-label text-base">
            <span>★ 840</span>
            <span class="material-symbols-outlined text-base">fork_right</span>
          </div>
        </div>
        <!-- Repo 3 -->
        <div class="bg-surface-container-low p-4 flex items-center justify-between hover:bg-surface-container transition-colors">
          <div class="flex items-center gap-4">
            <span class="material-symbols-outlined text-primary">folder</span>
            <div>
              <span class="block font-label text-lg font-bold">particle-track-ai</span>
              <span class="text-base text-outline uppercase">PyTorch / Rust</span>
            </div>
          </div>
          <div class="flex items-center gap-4 text-outline font-label text-base">
            <span>★ 2.4k</span>
            <span class="material-symbols-outlined text-base">fork_right</span>
          </div>
        </div>
      </div>
    </section>
    
    <!-- Contact Section -->
    <section class="border-t border-outline-variant pt-24 scroll-mt-28" id="contact">
      <div class="space-y-4">
        <h2 class="font-headline text-4xl font-bold tracking-tight">GET_IN_TOUCH</h2>
        <p class="font-label text-base text-outline uppercase tracking-widest">Direct channels for collaboration</p>
      </div>
      <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-6">
        <a class="group bg-surface-container p-5 flex items-center justify-between hover:bg-surface-container-highest transition-colors" href="mailto:chinskylee@outlook.com">
          <div class="space-y-1">
            <span class="font-label text-base text-outline uppercase">Email</span>
            <span class="block font-headline text-2xl font-semibold tracking-tight">chinskylee@outlook.com</span>
          </div>
          <span class="material-symbols-outlined text-base text-outline group-hover:translate-x-1 transition-transform">north_east</span>
        </a>
        <a class="group bg-surface-container p-5 flex items-center justify-between hover:bg-surface-container-highest transition-colors" href="https://github.com/chinskylee" rel="noopener noreferrer" target="_blank">
          <div class="space-y-1">
            <span class="font-label text-base text-outline uppercase">GitHub</span>
            <span class="block font-headline text-2xl font-semibold tracking-tight">github.com/chinskylee</span>
          </div>
          <span class="material-symbols-outlined text-base text-outline group-hover:translate-x-1 transition-transform">north_east</span>
        </a>
      </div>
    </section>
  </main>

  <!-- Custom Scroll Snap Script -->
  <script is:inline>
    (function() {
      // 等待 DOM 加载
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initScrollSnap);
      } else {
        initScrollSnap();
      }

      function initScrollSnap() {
        const hero = document.querySelector('section'); // Hero 是第一个 section
        const terminalLog = document.querySelector('.bg-surface-container-low'); // TerminalLog

        if (!hero || !terminalLog) return;

        let isSnapping = false;
        let lastScrollY = window.scrollY;
        const snapThreshold = 150; // 吸附触发距离（像素）
        const snapDuration = 400; // 吸附动画时长（毫秒）

        // 使用 requestAnimationFrame 节流
        let ticking = false;

        window.addEventListener('scroll', function() {
          if (isSnapping || ticking) return;

          ticking = true;
          window.requestAnimationFrame(function() {
            handleScroll();
            ticking = false;
          });
        }, { passive: true });

        function handleScroll() {
          const currentScrollY = window.scrollY;
          const scrollDirection = currentScrollY > lastScrollY ? 'down' : 'up';
          lastScrollY = currentScrollY;

          // 只在向下滚动时处理
          if (scrollDirection !== 'down') return;

          const terminalRect = terminalLog.getBoundingClientRect();
          const terminalTop = terminalRect.top;

          // 如果 TerminalLog 接近视口顶部（在阈值范围内），吸附到它
          if (terminalTop > 80 && terminalTop < 80 + snapThreshold) {
            snapToElement(terminalLog);
          }
        }

        function snapToElement(element) {
          isSnapping = true;
          const targetY = element.offsetTop - 80; // 80px 是 navbar 高度

          // 使用原生 smooth scroll
          window.scrollTo({
            top: targetY,
            behavior: 'smooth'
          });

          // 动画结束后重置标志
          setTimeout(function() {
            isSnapping = false;
          }, snapDuration);
        }
      }
    })();
  </script>

  <Footer />
</BaseLayout>